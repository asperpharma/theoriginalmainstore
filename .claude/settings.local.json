  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix \"$TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "grep -n 'console.log' \"$TOOL_INPUT_FILE_PATH\" 2>/dev/null && echo '[Hook] Remove console.log' >&2 || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT_FILE_PATH\" | grep -qE \"\\.env\" && echo \"BLOCKED: Cannot edit .env files\" && exit 1 || true"
          }
        ]
      }
    ]
  }
