# ─── Supabase (Frontend) ──────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# ─── Supabase (API / Server-side) ─────────────────────────────────────────────
# NEVER expose these in the browser. Set only in Vercel environment variables.
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── hCaptcha ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.hcaptcha.com
# Leave empty in development to use the test key (10000000-ffff-ffff-ffff-000000000001)
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# ─── Webhooks ─────────────────────────────────────────────────────────────────
# Shared secret for POST /api/webhooks/orders (status update webhook)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to "true" to enable experimental antigravity feature
VITE_FEATURE_ANTIGRAVITY=false

# ─── Supabase Edge Functions (set in Supabase Dashboard → Edge Functions → Secrets) ──
# GEMINI_API_KEY=your-gemini-api-key
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# ALLOWED_ORIGIN=https://www.asperbeautyshop.com

# ─── Set automatically by Vercel (do not set manually) ───────────────────────
# VERCEL_GIT_COMMIT_SHA=auto
