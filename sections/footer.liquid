{%- comment -%}
  sections/footer.liquid
  Site shell footer. Burgundy, gold accents, four columns on desktop.
{%- endcomment -%}

<footer class="aft" data-section-id="{{ section.id }}">
  <div class="aft__inner luxury-container">
    <div class="aft__grid">
      <div class="aft__col aft__col--brand">
        <a href="{{ routes.root_url }}" class="aft__logo">{{ shop.name }}</a>
        {%- if section.settings.tagline != blank -%}
          <p class="aft__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}

        {%- if section.settings.show_socials -%}
          <div class="aft__socials">
            {%- if section.settings.instagram != blank -%}
              <a href="{{ section.settings.instagram }}" class="aft__social" aria-label="Instagram" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.tiktok != blank -%}
              <a href="{{ section.settings.tiktok }}" class="aft__social" aria-label="TikTok" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.whatsapp != blank -%}
              <a href="{{ section.settings.whatsapp }}" class="aft__social" aria-label="WhatsApp" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'links' -%}
          <div class="aft__col" {{ block.shopify_attributes }}>
            <h3 class="aft__col-heading">{{ block.settings.heading }}</h3>
            {%- if block.settings.menu != blank -%}
              <ul class="aft__col-list">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div class="aft__col aft__col--newsletter">
        <h3 class="aft__col-heading">{{ section.settings.newsletter_heading }}</h3>
        <p class="aft__newsletter-sub">{{ section.settings.newsletter_subtitle }}</p>
        {%- form 'customer', class: 'aft__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
            required
            class="aft__newsletter-input"
            aria-label="Email"
          >
          <button type="submit" class="aft__newsletter-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </button>
        {%- endform -%}
      </div>
    </div>

    <div class="aft__bottom">
      <p class="aft__copy">
        © {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'general.footer.rights_reserved' | t }}
      </p>
      <div class="aft__legal">
        {%- if section.settings.legal_menu != blank -%}
          {%- for link in section.settings.legal_menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

<style>
  .aft {
    background: hsl(var(--burgundy));
    color: hsl(var(--polished-white));
    padding: var(--space-3xl) 0 var(--space-xl) 0;
    position: relative;
  }
  .aft::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, hsl(var(--polished-gold) / 0.5), transparent);
  }

  .aft__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }

  .aft__logo {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 600;
    color: hsl(var(--polished-gold));
    text-decoration: none;
    letter-spacing: 0.05em;
  }
  .aft__tagline {
    font-size: 13px;
    line-height: 1.6;
    color: hsl(var(--polished-white) / 0.7);
    margin: var(--space-md) 0 var(--space-lg) 0;
    max-width: 280px;
  }

  .aft__socials { display: flex; gap: var(--space-sm); }
  .aft__social {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid hsl(var(--polished-gold) / 0.3);
    color: hsl(var(--polished-gold));
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s var(--ease-luxury);
  }
  .aft__social:hover {
    background: hsl(var(--polished-gold));
    color: hsl(var(--burgundy));
  }

  .aft__col-heading {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: hsl(var(--polished-gold));
    margin: 0 0 var(--space-md) 0;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .aft__col-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .aft__col-list li { margin-bottom: 10px; }
  .aft__col-list a {
    font-size: 13px;
    color: hsl(var(--polished-white) / 0.7);
    text-decoration: none;
    transition: color 0.3s var(--ease-luxury);
  }
  .aft__col-list a:hover { color: hsl(var(--polished-gold)); }

  .aft__newsletter-sub {
    font-size: 13px;
    color: hsl(var(--polished-white) / 0.7);
    margin: 0 0 var(--space-md) 0;
  }
  .aft__newsletter-form {
    display: flex;
    gap: 0;
    border: 1px solid hsl(var(--polished-gold) / 0.3);
    border-radius: 100px;
    overflow: hidden;
    padding: 4px 4px 4px 16px;
    background: hsl(var(--burgundy-dark));
  }
  .aft__newsletter-input {
    flex: 1;
    background: transparent;
    border: 0;
    color: hsl(var(--polished-white));
    font-family: var(--font-body);
    font-size: 13px;
    outline: 0;
    padding: 8px 0;
  }
  .aft__newsletter-input::placeholder { color: hsl(var(--polished-white) / 0.4); }
  .aft__newsletter-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: hsl(var(--polished-gold));
    color: hsl(var(--burgundy));
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s var(--ease-luxury);
    cursor: pointer;
  }
  .aft__newsletter-btn:hover { transform: scale(1.08); }

  .aft__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-lg);
    border-top: 1px solid hsl(var(--polished-gold) / 0.2);
    font-size: 12px;
    color: hsl(var(--polished-white) / 0.5);
    flex-wrap: wrap;
    gap: var(--space-md);
  }
  .aft__copy { margin: 0; }
  .aft__legal { display: flex; gap: var(--space-md); }
  .aft__legal a {
    color: hsl(var(--polished-white) / 0.5);
    text-decoration: none;
    transition: color 0.3s var(--ease-luxury);
  }
  .aft__legal a:hover { color: hsl(var(--polished-gold)); }

  @media (max-width: 900px) {
    .aft__grid { grid-template-columns: 1fr 1fr; gap: var(--space-xl); }
    .aft__col--newsletter { grid-column: 1 / -1; }
    .aft__bottom { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 600px) {
    .aft__grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline",
      "default": "Pharmacist-curated skincare and beauty for the modern Levantine ritual." },

    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter heading",
      "default": "Join the Ritual" },
    { "type": "text", "id": "newsletter_subtitle", "label": "Subtitle",
      "default": "Weekly edits, pharmacist picks, and exclusive offers." },

    { "type": "header", "content": "Social Links" },
    { "type": "checkbox", "id": "show_socials", "label": "Show social icons", "default": true },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok",    "label": "TikTok URL" },
    { "type": "url", "id": "whatsapp",  "label": "WhatsApp URL" },

    { "type": "header", "content": "Legal" },
    { "type": "link_list", "id": "legal_menu", "label": "Legal menu" }
  ],
  "blocks": [
    {
      "type": "links",
      "name": "Link column",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ]
}
{% endschema %}
