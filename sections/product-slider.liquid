{%- comment -%}
  sections/product-slider.liquid
  Translated from src/components/home/ProductSlider.tsx
  Horizontal product carousel. Uses CSS scroll-snap for native smooth scrolling.
  No carousel library dependency.
{%- endcomment -%}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 8
-%}

<section class="aps" data-section-id="{{ section.id }}">
  <div class="aps__inner luxury-container">
    <div class="aps__head">
      <div class="aps__head-text">
        {%- if section.settings.subtitle != blank -%}
          <span class="aps__eyebrow">{{ section.settings.subtitle }}</span>
        {%- endif -%}
        <h2 class="aps__heading">{{ section.settings.heading }}</h2>
      </div>

      <div class="aps__controls">
        <button
          type="button"
          class="aps__btn"
          data-aps-prev
          aria-label="Previous"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6"/>
          </svg>
        </button>
        <button
          type="button"
          class="aps__btn"
          data-aps-next
          aria-label="Next"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="aps__track" data-aps-track>
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          <div class="aps__slide">
            {%- render 'product-card', product: product -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Placeholder slides when no collection picked yet {%- endcomment -%}
        {%- for i in (1..6) -%}
          <div class="aps__slide aps__slide--placeholder">
            <div class="apc__media apc__image--placeholder" style="aspect-ratio: 3/4; border-radius: var(--radius);"></div>
            <div style="padding-top: var(--space-md);">
              <div style="height: 12px; width: 40%; background: hsl(var(--asper-stone-dark)); border-radius: 4px; margin-bottom: 8px;"></div>
              <div style="height: 16px; width: 80%; background: hsl(var(--asper-stone-dark)); border-radius: 4px;"></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="aps__cta-row">
        <a href="{{ section.settings.cta_url | default: collection.url | default: '/collections/all' }}" class="btn-gold">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var track = section.querySelector('[data-aps-track]');
    var prev  = section.querySelector('[data-aps-prev]');
    var next  = section.querySelector('[data-aps-next]');
    if (!track) return;

    function scrollByOne(dir) {
      var slide = track.querySelector('.aps__slide');
      if (!slide) return;
      var width = slide.offsetWidth + 24; // gap
      track.scrollBy({ left: dir * width, behavior: 'smooth' });
    }

    if (prev) prev.addEventListener('click', function () { scrollByOne(-1); });
    if (next) next.addEventListener('click', function () { scrollByOne(1); });

    // RTL: reverse the buttons logically
    if (document.documentElement.dir === 'rtl') {
      if (prev) prev.addEventListener('click', function (e) { e.stopImmediatePropagation(); scrollByOne(1); }, { capture: true });
      if (next) next.addEventListener('click', function (e) { e.stopImmediatePropagation(); scrollByOne(-1); }, { capture: true });
    }
  })();
</script>

<style>
  .aps {
    padding: var(--space-3xl) 0;
    background: hsl(var(--asper-stone));
  }
  .aps__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid hsl(var(--polished-gold) / 0.2);
  }
  .aps__eyebrow {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: hsl(var(--polished-gold));
    margin-bottom: var(--space-sm);
  }
  .aps__heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 40px);
    color: hsl(var(--asper-ink));
    line-height: 1.15;
    margin: 0;
  }
  html[dir="rtl"] .aps__heading { font-family: var(--font-arabic); }

  .aps__controls {
    display: flex;
    gap: var(--space-sm);
  }
  .aps__btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: transparent;
    border: 1px solid hsl(var(--polished-gold) / 0.4);
    color: hsl(var(--burgundy));
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s var(--ease-luxury);
  }
  .aps__btn:hover {
    background: hsl(var(--polished-gold));
    color: hsl(var(--asper-stone));
    transform: translateY(-1px);
  }

  .aps__track {
    display: flex;
    gap: var(--space-lg);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding-bottom: var(--space-md);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .aps__track::-webkit-scrollbar { display: none; }

  .aps__slide {
    flex: 0 0 auto;
    width: calc(25% - 18px);
    scroll-snap-align: start;
  }
  @media (max-width: 1024px) {
    .aps__slide { width: calc(33.333% - 16px); }
  }
  @media (max-width: 768px) {
    .aps__slide { width: calc(50% - 12px); }
  }
  @media (max-width: 480px) {
    .aps__slide { width: calc(75% - 12px); }
  }

  .aps__cta-row {
    margin-top: var(--space-xl);
    text-align: center;
  }
</style>

{% schema %}
{
  "name": "Product Slider",
  "tag": "section",
  "class": "section-product-slider",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtitle / eyebrow",
      "default": "Most Loved" },
    { "type": "text", "id": "heading", "label": "Heading",
      "default": "Bestsellers" },
    { "type": "collection", "id": "collection", "label": "Source collection" },
    { "type": "range", "id": "products_to_show", "label": "Number of products",
      "min": 4, "max": 16, "step": 1, "default": 8 },
    { "type": "text", "id": "cta_label", "label": "CTA label",
      "default": "Browse the Edit" },
    { "type": "url",  "id": "cta_url",   "label": "CTA URL" }
  ],
  "presets": [
    { "name": "Product Slider" }
  ]
}
{% endschema %}
