{%- comment -%}
  sections/science-meets-elegance-split.liquid
  Translated from src/components/home/ScienceMeetsEleganceSplit.tsx
  Preserves: 50/50 desktop split, dual-persona framing, frosted glass cards,
             radial glow background, hover scale on background images.
{%- endcomment -%}

<section class="smes" data-section-id="{{ section.id }}">
  {%- comment -%} Subtle radial glows behind the glass for depth {%- endcomment -%}
  <div class="smes__glow" aria-hidden="true"></div>

  <div class="smes__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'persona' -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="smes__panel smes__panel--{{ forloop.index }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.bg_image != blank -%}
            <div
              class="smes__bg"
              style="background-image: url('{{ block.settings.bg_image | image_url: width: 1200 }}');"
              aria-hidden="true"
            ></div>
          {%- endif -%}

          <div class="smes__card clinical-glass scroll-reveal">
            <div class="smes__pill">
              {%- if block.settings.icon == 'stethoscope' -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/>
                  <path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"/>
                  <circle cx="20" cy="10" r="2"/>
                </svg>
              {%- else -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/>
                </svg>
              {%- endif -%}
              <span>{{ block.settings.pill_label }}</span>
            </div>

            <span class="smes__eyebrow">{{ block.settings.eyebrow }}</span>

            <h2 class="smes__heading">{{ block.settings.heading }}</h2>

            {%- if block.settings.body != blank -%}
              <p class="smes__body">{{ block.settings.body }}</p>
            {%- endif -%}

            <span class="smes__cta">
              {{ block.settings.cta_label }}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .smes {
    position: relative;
    width: 100%;
    background: hsl(var(--asper-stone));
    overflow: hidden;
  }
  .smes__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 50% 50% at 25% 50%, hsl(var(--polished-gold) / 0.04) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 75% 50%, hsl(var(--burgundy) / 0.03) 0%, transparent 60%);
  }
  .smes__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 70vh;
    position: relative;
    z-index: 1;
  }
  .smes__panel {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: var(--space-3xl) var(--space-xl);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }
  .smes__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.06;
    transition: opacity 0.8s var(--ease-luxury), transform 0.8s var(--ease-luxury);
  }
  .smes__panel:hover .smes__bg {
    opacity: 0.12;
    transform: scale(1.02);
  }

  .smes__card {
    position: relative;
    z-index: 2;
    padding: 40px;
    max-width: 460px;
    width: 100%;
  }

  .smes__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: hsl(var(--asper-stone-dark) / 0.8);
    border: 1px solid hsl(var(--polished-gold) / 0.3);
    border-radius: 100px;
    color: hsl(var(--polished-gold));
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
    backdrop-filter: blur(6px);
  }

  .smes__eyebrow {
    display: block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: hsl(var(--polished-gold));
    margin-bottom: var(--space-md);
  }

  .smes__heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 42px);
    line-height: 1.15;
    color: hsl(var(--burgundy));
    margin: 0 0 var(--space-md) 0;
  }
  html[dir="rtl"] .smes__heading { font-family: var(--font-arabic); }

  .smes__body {
    font-size: 15px;
    line-height: 1.7;
    color: hsl(var(--asper-ink-muted));
    margin: 0 0 var(--space-xl) 0;
  }

  .smes__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: hsl(var(--polished-gold));
    transition: gap 0.3s var(--ease-luxury);
  }
  .smes__panel:hover .smes__cta {
    gap: 14px;
  }

  @media (max-width: 768px) {
    .smes__grid { grid-template-columns: 1fr; min-height: auto; }
    .smes__panel { padding: var(--space-2xl) var(--space-lg); }
  }
</style>

{% schema %}
{
  "name": "Science Meets Elegance",
  "tag": "section",
  "class": "section-smes",
  "settings": [],
  "blocks": [
    {
      "type": "persona",
      "name": "Persona panel",
      "limit": 2,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "stethoscope", "label": "Stethoscope (clinical)" },
            { "value": "sparkles",    "label": "Sparkles (beauty)" }
          ],
          "default": "stethoscope"
        },
        { "type": "text", "id": "pill_label", "label": "Pill label",
          "default": "Dr. Sami's Domain" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow",
          "default": "The Clinical Side" },
        { "type": "text", "id": "heading", "label": "Heading",
          "default": "Discover Your Ideal Serum" },
        { "type": "textarea", "id": "body", "label": "Body copy",
          "default": "Pharmacist-curated formulas backed by clinical evidence." },
        { "type": "text", "id": "cta_label", "label": "CTA label",
          "default": "Browse Clinical" },
        { "type": "url", "id": "link", "label": "Panel link" },
        { "type": "image_picker", "id": "bg_image", "label": "Background image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Science Meets Elegance",
      "blocks": [
        {
          "type": "persona",
          "settings": {
            "icon": "stethoscope",
            "pill_label": "Dr. Sami's Domain",
            "eyebrow": "The Clinical Side",
            "heading": "Discover Your Ideal Serum",
            "body": "Pharmacist-curated formulas backed by clinical evidence.",
            "cta_label": "Browse Clinical"
          }
        },
        {
          "type": "persona",
          "settings": {
            "icon": "sparkles",
            "pill_label": "Ms. Zain's Domain",
            "eyebrow": "The Aesthetic Side",
            "heading": "Curate Your Daily Ritual",
            "body": "Beauty essentials chosen for the modern Levantine routine.",
            "cta_label": "Browse Beauty"
          }
        }
      ]
    }
  ]
}
{% endschema %}
