{%- comment -%}
  sections/usp-bar.liquid
  Translated from src/components/home/USPBar.tsx
  Burgundy strip with three USPs: gifts, delivery, deals.
{%- endcomment -%}

<section class="usp" data-section-id="{{ section.id }}">
  <div class="usp__inner luxury-container">
    {%- for block in section.blocks -%}
      {%- if block.type == 'usp' -%}
        <div class="usp__item" {{ block.shopify_attributes }}>
          <div class="usp__icon-wrap neu-raised-dark">
            {%- case block.settings.icon -%}
              {%- when 'gift' -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="8" width="18" height="4" rx="1"/>
                  <path d="M12 8v13M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/>
                  <path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/>
                </svg>
              {%- when 'truck' -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/>
                  <path d="M15 18H9M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/>
                  <circle cx="17" cy="18" r="2"/>
                  <circle cx="7" cy="18" r="2"/>
                </svg>
              {%- when 'tag' -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/>
                  <circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>
                </svg>
              {%- else -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <circle cx="12" cy="12" r="9"/>
                </svg>
            {%- endcase -%}
          </div>
          <div class="usp__text">
            <p class="usp__title">{{ block.settings.title }}</p>
            <p class="usp__sub">{{ block.settings.subtitle }}</p>
          </div>
          {%- unless forloop.last -%}
            <div class="usp__divider" aria-hidden="true"></div>
          {%- endunless -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .usp {
    background: hsl(var(--burgundy));
    padding: var(--space-xl) 0;
    position: relative;
  }
  .usp__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-lg);
  }
  @media (min-width: 640px) {
    .usp__inner { gap: 48px; }
  }
  @media (min-width: 1024px) {
    .usp__inner { gap: 80px; }
  }
  .usp__item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }
  .usp__icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: hsl(var(--burgundy));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid hsl(var(--polished-gold) / 0.2);
    color: hsl(var(--polished-gold));
  }
  .usp__text { text-align: start; }
  .usp__title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: hsl(var(--polished-white));
    line-height: 1.2;
    margin: 0 0 2px 0;
  }
  .usp__sub {
    font-family: var(--font-body);
    font-size: 11px;
    color: hsl(var(--polished-gold) / 0.7);
    margin: 0;
  }
  .usp__divider {
    display: none;
    width: 1px;
    height: 32px;
    background: hsl(var(--polished-gold) / 0.2);
    margin-inline-start: 24px;
  }
  @media (min-width: 640px) {
    .usp__divider { display: block; }
  }
  html[dir="rtl"] .usp__title,
  html[dir="rtl"] .usp__sub {
    font-family: var(--font-arabic);
  }
</style>

{% schema %}
{
  "name": "USP Bar",
  "tag": "section",
  "class": "section-usp",
  "settings": [],
  "blocks": [
    {
      "type": "usp",
      "name": "USP item",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "gift",  "label": "Gift" },
            { "value": "truck", "label": "Truck (delivery)" },
            { "value": "tag",   "label": "Tag (offer)" }
          ],
          "default": "gift"
        },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" }
      ]
    }
  ],
  "presets": [
    {
      "name": "USP Bar",
      "blocks": [
        { "type": "usp", "settings": { "icon": "gift",  "title": "2 Free Samples",   "subtitle": "With every order" } },
        { "type": "usp", "settings": { "icon": "truck", "title": "Fast Delivery",    "subtitle": "3–6 business days" } },
        { "type": "usp", "settings": { "icon": "tag",   "title": "Free Beauty Deals","subtitle": "Exclusive offers weekly" } }
      ]
    }
  ]
}
{% endschema %}
