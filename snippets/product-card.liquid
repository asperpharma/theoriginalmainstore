{%- comment -%}
  snippets/product-card.liquid
  Reusable product card. Pass:
    - product: a Shopify product object
    - heading_size: 'small' or 'medium' (optional, default 'small')
{%- endcomment -%}

{%- liquid
  assign heading_size = heading_size | default: 'small'
  assign image_url = product.featured_image | image_url: width: 600
  assign on_sale = product.compare_at_price > product.price
-%}

<a
  href="{{ product.url }}"
  class="apc apc--{{ heading_size }}"
  aria-label="{{ product.title | escape }}"
>
  <div class="apc__media">
    {%- if product.featured_image != blank -%}
      {{
        product.featured_image
        | image_url: width: 600
        | image_tag:
          alt: product.featured_image.alt | default: product.title,
          loading: 'lazy',
          sizes: '(max-width: 768px) 50vw, 280px',
          widths: '280, 400, 600',
          class: 'apc__image'
      }}
    {%- else -%}
      <div class="apc__image apc__image--placeholder"></div>
    {%- endif -%}

    {%- if product.tags contains 'bestseller' or product.tags contains 'Bestseller' -%}
      <span class="apc__badge apc__badge--bestseller">Bestseller</span>
    {%- elsif on_sale -%}
      <span class="apc__badge apc__badge--sale">Sale</span>
    {%- endif -%}
  </div>

  <div class="apc__info">
    {%- if product.vendor != blank -%}
      <span class="apc__brand">{{ product.vendor }}</span>
    {%- endif -%}

    <h3 class="apc__title">{{ product.title }}</h3>

    <div class="apc__price-row">
      {%- if on_sale -%}
        <span class="apc__price-compare">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
      <span class="apc__price">{{ product.price | money }}</span>
    </div>
  </div>
</a>

<style>
  .apc {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.4s var(--ease-luxury);
  }
  .apc:hover { transform: translateY(-3px); }

  .apc__media {
    position: relative;
    aspect-ratio: 3/4;
    background: hsl(var(--asper-stone-light));
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: var(--space-md);
  }
  .apc__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-luxury);
  }
  .apc:hover .apc__image { transform: scale(1.04); }
  .apc__image--placeholder {
    background: linear-gradient(135deg, hsl(var(--asper-stone-light)) 0%, hsl(var(--asper-stone-dark)) 100%);
  }

  .apc__badge {
    position: absolute;
    top: 12px;
    inset-inline-start: 12px;
    padding: 4px 10px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .apc__badge--bestseller {
    background: hsl(var(--polished-gold));
    color: hsl(var(--asper-ink));
  }
  .apc__badge--sale {
    background: hsl(var(--burgundy));
    color: hsl(var(--polished-white));
  }

  .apc__brand {
    display: block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: hsl(var(--polished-gold));
    margin-bottom: 4px;
  }
  .apc__title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: hsl(var(--asper-ink));
    line-height: 1.3;
    margin: 0 0 8px 0;
  }
  html[dir="rtl"] .apc__title { font-family: var(--font-arabic); }

  .apc__price-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .apc__price {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: hsl(var(--burgundy));
  }
  .apc__price-compare {
    font-size: 13px;
    color: hsl(var(--asper-ink-muted));
    text-decoration: line-through;
  }
</style>
